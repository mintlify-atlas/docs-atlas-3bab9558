  "keyFeatures": [
    "LangGraph-based agent orchestration with sub-agent delegation",
    "Isolated sandbox execution environment with Docker/Kubernetes support",
    "Extensible skills system with progressive loading",
    "Long-term memory with fact extraction and context management",
    "MCP server integration with OAuth support",
    "Multi-model support with vision and reasoning capabilities",
    "Middleware chain for context engineering and summarization",
    "Embedded Python client and REST API",
    "Thread-isolated filesystem with automatic file conversion",
    "Real-time streaming with SSE protocol"
  ],
  "publicApiSurface": [
    "DeerFlowClient - Embedded Python client for in-process agent access",
    "DeerFlowClient.chat() - Synchronous chat interface",
    "DeerFlowClient.stream() - Streaming chat with SSE protocol",
    "DeerFlowClient.list_models() - List available LLM models",
    "DeerFlowClient.list_skills() - List available skills",
    "DeerFlowClient.update_skill() - Enable/disable skills",
    "DeerFlowClient.upload_files() - Upload files to thread",
    "DeerFlowClient.get_memory() - Access long-term memory",
    "Gateway API: /api/models - Model management endpoints",
    "Gateway API: /api/agents - Custom agents with SOUL.md profiles",
    "Gateway API: /api/user-profile - Global user profile (USER.md)",
    "Gateway API: /api/skills - Skills management endpoints",
    "Gateway API: /api/mcp - MCP server configuration",
    "Gateway API: /api/memory - Memory management",
    "Gateway API: /api/threads/{id}/uploads - File upload endpoints",
    "Gateway API: /api/threads/{id}/artifacts - Artifact serving",
    "LangGraph API: /api/langgraph/threads - Thread management",
    "LangGraph API: /api/langgraph/runs - Agent runs and streaming",
    "Sandbox Tools: bash, ls, read_file, write_file, str_replace",
    "Built-in Tools: present_files, ask_clarification, view_image",
    "Sub-agent Tool: task() - Delegate to sub-agents",
    "Community Tools: tavily_search, web_fetch, firecrawl, image_search"
  ]
